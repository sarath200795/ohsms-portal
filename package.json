{
  "name": "ohsms-enterprise",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:field-portal": "vite build --config vite.field-portal.config.js",
    "build:all": "npm run build && npm run build:field-portal",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:field-portal": "vite preview --config vite.field-portal.config.js",
    "video:record:public": "node scripts/video-guides/record-public-sample.mjs",
    "video:record:guided": "node scripts/video-guides/record-guided-video.mjs",
    "video:record:intro-promo": "node scripts/video-guides/record-app-intro-promo.mjs",
    "video:record:incident-deep-dive": "node scripts/video-guides/record-incident-live-tutorial.mjs",
    "video:record:inspections-deep-dive": "node scripts/video-guides/record-inspections-live-tutorial.mjs",
    "video:record:emergency-deep-dive": "node scripts/video-guides/record-emergency-live-tutorial.mjs",
    "video:record:risk-deep-dive": "node scripts/video-guides/record-risk-live-tutorial.mjs",
    "video:record:training-deep-dive": "node scripts/video-guides/record-training-live-tutorial.mjs",
    "video:record:contractors-deep-dive": "node scripts/video-guides/record-contractors-live-tutorial.mjs",
    "video:record:vendor-portal-deep-dive": "node scripts/video-guides/record-vendor-portal-live-tutorial.mjs",
    "video:record:loto-deep-dive": "node scripts/video-guides/record-loto-live-tutorial.mjs",
    "video:record:ptw-deep-dive": "node scripts/video-guides/record-ptw-live-tutorial.mjs",
    "video:record:emergency-equipment-deep-dive": "node scripts/video-guides/record-emergency-equipment-live-tutorial.mjs",
    "video:record:modules": "node scripts/video-guides/render-all-modules.mjs",
    "video:record:minute-modules": "node scripts/video-guides/render-minute-modules.mjs",
    "video:record:tutorial-modules": "node scripts/video-guides/render-tutorial-modules.mjs",
    "firebase:deploy": "firebase deploy --only database,hosting:app",
    "firebase:deploy:field-portal": "npm run build:field-portal && firebase deploy --only hosting:fieldportal",
    "firebase:rules": "firebase deploy --only database"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.9.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "qrious": "^4.0.2",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "ffmpeg-static": "^5.3.0",
    "globals": "^16.5.0",

{
  "name": "ohsms-enterprise",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:field-portal": "vite build --config vite.field-portal.config.js",
    "build:all": "npm run build && npm run build:field-portal",
    "test:phase1": "node --test --test-isolation=none tests/permissions.test.mjs tests/user-access.test.mjs",
    "test:platform": "node --test --test-isolation=none tests/permissions.test.mjs tests/user-access.test.mjs tests/contractor-incidents.test.mjs tests/incidents-utils.test.mjs tests/database-rules.test.mjs tests/field-qr.test.mjs tests/vendor-portal-email.test.mjs tests/reminders.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/App.jsx src/FieldPortalApp.jsx src/main.jsx src/fieldPortalMain.jsx src/components src/hooks src/utils src/pages/Audit.jsx src/pages/Incidents/FullScreenIncidents.jsx src/pages/Contractors/components/CompanyProfileModal.jsx src/pages/FieldApp/components/FieldQrScannerModal.jsx tests --report-unused-disable-directives --max-warnings 0",
    "lint:full": "eslint . --report-unused-disable-directives",
    "preview": "vite preview",
    "preview:field-portal": "vite preview --config vite.field-portal.config.js",
    "video:record:public": "node scripts/video-guides/record-public-sample.mjs",
    "video:record:guided": "node scripts/video-guides/record-guided-video.mjs",
    "video:record:intro-promo": "node scripts/video-guides/record-app-intro-promo.mjs",
    "video:record:incident-deep-dive": "node scripts/video-guides/record-incident-live-tutorial.mjs",
    "video:record:inspections-deep-dive": "node scripts/video-guides/record-inspections-live-tutorial.mjs",
    "video:record:emergency-deep-dive": "node scripts/video-guides/record-emergency-live-tutorial.mjs",
    "video:record:risk-deep-dive": "node scripts/video-guides/record-risk-live-tutorial.mjs",
    "video:record:training-deep-dive": "node scripts/video-guides/record-training-live-tutorial.mjs",
    "video:record:contractors-deep-dive": "node scripts/video-guides/record-contractors-live-tutorial.mjs",
    "video:record:vendor-portal-deep-dive": "node scripts/video-guides/record-vendor-portal-live-tutorial.mjs",
    "video:record:loto-deep-dive": "node scripts/video-guides/record-loto-live-tutorial.mjs",
    "video:record:ptw-deep-dive": "node scripts/video-guides/record-ptw-live-tutorial.mjs",
    "video:record:emergency-equipment-deep-dive": "node scripts/video-guides/record-emergency-equipment-live-tutorial.mjs",
    "video:record:audit-capa": "node scripts/video-guides/record-live-requested-tutorials.mjs audit-capa",
    "video:record:organization-onboarding": "node scripts/video-guides/record-live-requested-tutorials.mjs organization-onboarding",
    "video:record:database-connection": "node scripts/video-guides/record-live-requested-tutorials.mjs database-connection",
    "video:record:requested-tutorials": "node scripts/video-guides/record-live-requested-tutorials.mjs",
    "video:record:onboarding": "node scripts/video-guides/record-onboarding-tutorial.mjs",
    "video:record:modules": "node scripts/video-guides/render-all-modules.mjs",
    "video:record:minute-modules": "node scripts/video-guides/render-minute-modules.mjs",
    "video:record:tutorial-modules": "node scripts/video-guides/render-tutorial-modules.mjs",
    "firebase:deploy": "firebase deploy --only database,hosting:app",
    "firebase:deploy:field-portal": "npm run build:field-portal && firebase deploy --only hosting:fieldportal",
    "firebase:rules": "firebase deploy --only database",
    "vercel:build:app": "npm run build",
    "vercel:build:field-portal": "npm run build:field-portal"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^2.2.13",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "qrcode.react": "^4.2.0",
    "qrious": "^4.0.2",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "ffmpeg-static": "^5.3.0",
    "globals": "^16.5.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.10"
  },
  "overrides": {
    "vite": "^8.0.10",
    "postcss": "^8.5.10",
    "dompurify": "^3.4.1",
    "protobufjs": "^7.5.8",
    "uuid": ">=11.1.1",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.2",
    "minimatch": {
      "brace-expansion": "^1.1.14"
    },
    "readdir-glob": {
      "brace-expansion": "^2.0.3"
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Organisation attachments ───────────────────────────────────────────
    // Path: organizations/{orgId}/attachments/{collection}/{recordId}/{filename}
    //
    // Access is scoped by orgId embedded in the path.  Any authenticated user
    // can read attachments for their own organisation; any active authenticated
    // user can upload.  Deletions are blocked from the client — use the
    // Firebase Admin SDK (server-side) if a record needs to be purged.

    match /organizations/{orgId}/attachments/{allPaths=**} {

      // Read: any authenticated user (the orgId in the path provides isolation
      // at the URL level; additional token-based checks require Firestore or a
      // custom token claim, which is a future hardening step).
      allow read: if request.auth != null;

      // Write: authenticated users only; max 100 MB per file.
      allow write: if request.auth != null
                   && request.resource.size <= 100 * 1024 * 1024;

      // Delete: blocked from the client — Admin SDK only.
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{allOtherPaths=**} {
      allow read, write: if false;
    }
  }
}

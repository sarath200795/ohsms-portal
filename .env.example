# ── Firebase client SDK (required) ───────────────────────────────────────────
# Copy from Firebase Console → Project Settings → Your apps → Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — reCAPTCHA v3 App Check for production hardening.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# ── Firebase Admin SDK (server-side — required for user creation/deletion) ────
# These are NOT VITE_ variables — they run only in Vercel serverless functions.
# In production: set them in Vercel dashboard → Settings → Environment Variables.
# Locally:       set them here (or in .env.local) and run `vercel dev` (not npm run dev).
#
# FIREBASE_SERVICE_ACCOUNT_JSON:
#   1. Firebase Console → Project Settings → Service accounts
#   2. Click "Generate new private key" → download the JSON file
#   3. Paste the entire JSON content as the value (minify it first if needed)
FIREBASE_SERVICE_ACCOUNT_JSON=

# FIREBASE_DATABASE_URL:
#   Same value as VITE_FIREBASE_DATABASE_URL above, but without the VITE_ prefix.
#   Required by the Admin SDK to connect to the Realtime Database.
FIREBASE_DATABASE_URL=

# ── Email delivery (optional) ─────────────────────────────────────────────────
# When set, newly created vendor portal accounts receive their temporary password by email.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID_VENDOR_CREDENTIALS=

# ── Incident AI backend (optional) ────────────────────────────────────────────
# Leave blank to use the bundled Vercel serverless function (api/v1.js).
# Set to an external URL to point at your own hosted AI service.
VITE_INCIDENT_AI_API_BASE_URL=

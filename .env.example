# ── Firebase (required for Firebase database adapter) ────────────────────────
# Copy these from Firebase Console → Project Settings → Your apps → Web app config.
# Rotate your API key in Firebase Console before deploying publicly.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — recommended for production hardening.
# Adds reCAPTCHA v3 App Check to prevent abuse of your Firebase project.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Optional — vendor portal email delivery.
# When set, newly created vendor portal accounts receive their temporary password by email.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID_VENDOR_CREDENTIALS=

# Optional — Incident AI backend.
# Leave blank to use the bundled Vercel serverless function (api/v1.js).
# Set to an external URL to point at your own hosted AI service.
VITE_INCIDENT_AI_API_BASE_URL=
